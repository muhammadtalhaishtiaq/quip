    "@typescript-eslint/parser": "^7.0.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.56.0",
    "postcss": "^8.4.33",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.1",
    "terser": "^5.46.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
