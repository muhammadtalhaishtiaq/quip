{
  "name": "quip",
  "version": "1.0.0",
  "description": "AI-powered comment generator for LinkedIn",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
