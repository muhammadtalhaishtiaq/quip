{
  "manifest_version": 3,
  "name": "Quip — AI Comment Generator",
  "version": "1.0.0",
  "description": "Generate AI-powered comments for LinkedIn with your OpenAI API key",
  "icons": {
    "16": "src/assets/icons/icon16.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Quip — AI Comment Generator"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "src/content/linkedin.ts"
      ],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.openai.com/*"
  ],
  "permissions": [
    "storage",
    "activeTab"
  ]
}
